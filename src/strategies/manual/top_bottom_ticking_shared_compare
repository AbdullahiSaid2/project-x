class ApexAccount:
    def __init__(
        self,
        starting_balance: float = REPORT_ACCOUNT_CASH,
        daily_loss_limit: float = APEX_DAILY_LOSS_LIMIT,
        max_consecutive_losses_per_day: int = APEX_MAX_CONSECUTIVE_LOSSES_PER_DAY,
    ):
        self.starting_balance = float(starting_balance)
        self.balance = float(starting_balance)
        self.daily_loss_limit = float(daily_loss_limit)
        self.max_consecutive_losses_per_day = int(max_consecutive_losses_per_day)

        self.current_day = None
        self.day_realized = 0.0
        self.consecutive_losses_today = 0

        self.rejected_daily_loss = 0
        self.rejected_consecutive_losses = 0
        self.rejected_total = 0

    def reset_day(self, trade_day):
        self.current_day = trade_day
        self.day_realized = 0.0
        self.consecutive_losses_today = 0

    def check_day_roll(self, trade_day):
        if self.current_day != trade_day:
            self.reset_day(trade_day)

    def can_keep_trade(self) -> tuple[bool, str | None]:
        if self.day_realized <= self.daily_loss_limit:
            self.rejected_daily_loss += 1
            self.rejected_total += 1
            return False, "daily_loss"

        if self.consecutive_losses_today >= self.max_consecutive_losses_per_day:
            self.rejected_consecutive_losses += 1
            self.rejected_total += 1
            return False, "consecutive_losses"

        return True, None

    def apply_trade(self, pnl: float):
        self.balance += float(pnl)
        self.day_realized += float(pnl)

        if pnl < 0:
            self.consecutive_losses_today += 1
        else:
            self.consecutive_losses_today = 0


