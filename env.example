# ============================================================
# 🌙 Algotec Trading System — Environment Variables
# Copy this file to .env and fill in your keys.
# NEVER commit your .env file!
# ============================================================

# ── AI Models (add as many as you like — system auto-fallbacks) ──
DEEPSEEK_API_KEY=your_deepseek_key_here     # platform.deepseek.com  (~$0.14/M tokens)
GROQ_API_KEY=your_groq_key_here             # console.groq.com       (FREE)
GEMINI_KEY=your_gemini_key_here             # aistudio.google.com    (FREE)
OPENAI_KEY=your_openai_key_here             # platform.openai.com    (optional)

# ── Hyperliquid (for live trading) ────────────────────────────
HYPERLIQUID_PRIVATE_KEY=your_hl_private_key_here
HYPERLIQUID_WALLET_ADDRESS=your_wallet_here

# ── Coinbase Advanced Trade (for live trading) ────────────────
COINBASE_API_KEY=your_coinbase_api_key_here
COINBASE_API_SECRET=your_coinbase_secret_here

# ── Databento (institutional futures data — databento.com) ──────
DATABENTO_API_KEY=db-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Market Data APIs (optional but recommended) ───────────────
COINGLASS_API_KEY=your_coinglass_key_here   # coinglass.com (free tier)

# ── Tradovate Futures (for live futures trading) ─────────────
TRADOVATE_USERNAME=your_tradovate_username
TRADOVATE_PASSWORD=your_tradovate_password
TRADOVATE_APP_ID=your_app_id
TRADOVATE_APP_VERSION=1.0
TRADOVATE_CID=your_cid
TRADOVATE_SECRET=your_secret
TRADOVATE_SIM=true     # set to false for live trading

# ── TradingView Webhook ───────────────────────────────────────
WEBHOOK_SECRET=algotec_secret_change_me   # change this to something unique
